				0xef101680 0x38399080 0x1493bb85
				0xb176345a 0xb0c739e0 0xc087b4f8
				0xfdd7d48b 0x779651b1 0x8b665529
				0x74716ede 0x3e1e23db 0x86e8fe1a
				0xd09c0f7a 0x140a6dc8>;
