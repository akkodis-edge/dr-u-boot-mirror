				0x3600a7ec 0x1571403d 0x92ae0c2c 0x9ddf5499
				0xeb746735 0x25b305b2 0xa5e06d70 0xcca62cc3
				0x1fcd97dc 0xa7902768 0x65b1d01e 0x7a150ece
				0xbc157a9d 0x6c0b02f4 0x2bf5021f 0x9a95468b
				0xd784f910 0x8d42b117 0xa4747dc8 0x83299ca9
				0x4e8cc2a8 0xcb451fe7 0xbc338b77 0x69e7ee8e
