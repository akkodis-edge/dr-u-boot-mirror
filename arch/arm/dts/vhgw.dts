/dts-v1/;

#include <dt-bindings/interrupt-controller/irq.h>
#include "imx8mn.dtsi"

/ {
	model = "Data Respons Solutions VHGW";
	compatible = "drs,vhgw", "fsl,imx8mn";

	aliases {
		spi0 = &ecspi1;
	};

	chosen {
		stdout-path = &uart2;
	};

	memory@40000000 {
		device_type = "memory";
		reg = <0x0 0x40000000 0 0x80000000>;
	};

	signature {
		key-datarespons {
			required = "conf";
			algo = "sha256,rsa4096";
			rsa,r-squared = <
				0x38934618 0xe5ed68ed 0xcf466e48
				0x801e626d 0xd3863a9e 0x0beb9a64
				0xc2a3a617 0x9df8208a 0x88e3f01e
