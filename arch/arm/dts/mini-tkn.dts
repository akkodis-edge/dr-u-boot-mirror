			IMX95_PAD_SD1_DATA1__USDHC1_DATA1		0x139e
			IMX95_PAD_SD1_DATA2__USDHC1_DATA2		0x139e
			IMX95_PAD_SD1_DATA3__USDHC1_DATA3		0x139e
			IMX95_PAD_SD1_DATA4__USDHC1_DATA4		0x139e
			IMX95_PAD_SD1_DATA5__USDHC1_DATA5		0x139e
